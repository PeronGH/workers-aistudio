{
  "name": "workers-ai-studio",
  "version": "1.0.0",
  "private": true,
  "description": "AI-Studio-style playground built on Cloudflare Workers AI",
  "keywords": [
    "ai",
    "cloudflare",
    "workers-ai"
  ],
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "start": "vite dev",
    "deploy": "vite build && wrangler deploy",
    "types": "wrangler types env.d.ts --include-runtime false",
    "format": "oxfmt --write .",
    "lint": "oxlint src/",
    "check": "oxfmt --check . && oxlint src/ && tsc"
  },
  "dependencies": {
    "@cloudflare/kumo": "^2.3.0",
    "@hono/zod-validator": "^0.8.0",
    "@phosphor-icons/react": "^2.1.10",
    "@streamdown/code": "^1.1.1",
    "hono": "^4.12.22",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "streamdown": "^2.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.36.4",
    "@cloudflare/workers-types": "^4.20260524.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.66.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "wrangler": "^4.94.0"
  }
}
